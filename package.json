  "description": "KaarigarGo backend API — Express + Prisma (PostgreSQL/PostGIS)",
  "private": true,
  "license": "UNLICENSED",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node --watch server/server.js",
