    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.2.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
