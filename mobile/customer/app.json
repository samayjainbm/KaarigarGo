{
  "expo": {
    "name": "KaarigarGo",
    "slug": "kaarigargo-customer",
    "scheme": "kaarigargo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#4f46e5",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.kaarigargo.customer"
    },
    "android": {
      "package": "app.kaarigargo.customer",
      "adaptiveIcon": {
        "backgroundColor": "#4f46e5"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://localhost:3000/api/v1"
    }
  }
}
